{
    "name": "panic-on-rails",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "packageManager": "pnpm@11.1.1",
    "engines": {
        "node": ">=24.0.0",
        "pnpm": ">=11.0.0"
    },
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "preview": "vite preview",
        "test": "vitest",
        "e2e": "playwright test --project=chromium",
        "e2e:dev": "PLAYWRIGHT_DEV=1 playwright test --project=dev",
        "e2e:headed": "playwright test --headed",
        "e2e:ui": "playwright test --ui",
        "e2e:report": "playwright show-report e2e-report"
    },
    "dependencies": {
        "file-saver": "^2.0.5",
        "immer": "^11.1.9",
        "konva": "^10.3.0",
        "lucide-react": "^1.23.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-konva": "^19.2.5",
        "uuid": "^13.0.0",
        "zod": "^4.4.3",
        "zustand": "^5.0.14"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@playwright/test": "^1.59.1",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/file-saver": "^2.0.7",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.0.0",
        "@types/uuid": "^11.0.0",
        "@vitejs/plugin-react": "^5.2.0",
        "eslint": "^9.17.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.5.0",
        "jsdom": "^29.0.1",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.59.0",
        "vite": "^7.3.1",
        "vitest": "^4.1.5"
    }
}
