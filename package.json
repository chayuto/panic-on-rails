{
    "name": "panic-on-rails",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "packageManager": "pnpm@11.1.1",
    "engines": {
        "node": ">=24.0.0",
        "pnpm": ">=11.0.0"
    },
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "lint": "eslint . --max-warnings 0",
        "typecheck": "tsc -b",
        "preview": "vite preview",
        "test": "vitest",
        "e2e": "playwright test --project=chromium",
        "e2e:dev": "PLAYWRIGHT_DEV=1 playwright test --project=dev",
        "e2e:headed": "playwright test --headed",
        "e2e:ui": "playwright test --ui",
        "e2e:report": "playwright show-report e2e-report"
    },
    "dependencies": {
        "file-saver": "^2.0.5",
        "immer": "^11.1.11",
        "konva": "^10.3.0",
        "lucide-react": "^1.24.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-konva": "^19.2.5",
        "uuid": "^14.0.1",
        "zod": "^4.4.3",
        "zustand": "^5.0.14"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.61.1",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/file-saver": "^2.0.7",
        "@types/node": "^26.1.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^6.0.3",
        "eslint": "^10.6.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "globals": "^17.7.0",
        "jsdom": "^29.0.1",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.63.0",
        "vite": "^8.1.5",
        "vitest": "^4.1.10"
    }
}
